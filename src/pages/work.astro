---
import { getCollection } from "astro:content";

import BaseLayout from "../layouts/BaseLayout.astro";

import ContactCTA from "../components/ContactCTA.astro";
import PortfolioPreview from "../components/PortfolioPreview.astro";
import Hero from "../components/Hero.astro";
import Grid from "../components/Grid.astro";

const projects = (await getCollection("work")).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout
  title="My Work | Jeanine White"
  description="Learn about Jeanine White's most recent projects"
>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <Hero
        title="Mes projets"
        tagline="Vous vous demandez peut-être, où sont les projets incroyables que j'ai réalisés jusqu'à présent ? Eh bien, je suis ravi de vous dire que je suis en train de les créer en ce moment ! Tout comme un chef prépare soigneusement ses ingrédients avant de concocter un plat exceptionnel, je suis actuellement en train de perfectionner mes compétences en travaillant sur des projets de formation et des projets personnels. Et en me recrutant, vous contribuerez à enrichir ce portfolio de manière significative !"
        align="center"
      />
    </main>
    <ContactCTA />
  </div>
</BaseLayout>
